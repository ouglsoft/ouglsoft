/404.html
  X-Robots-Tag: noindex, nofollow
  Cache-Control: no-cache, max-age=0, must-revalidate

/download/*
  X-Robots-Tag: noindex, nofollow
  Cache-Control: no-cache, max-age=0, must-revalidate

/assets/downloads/releases.json
  X-Robots-Tag: noindex, nofollow
  Cache-Control: no-cache, max-age=0, must-revalidate
  X-Content-Type-Options: nosniff

/assets/downloads/apps/*
  Content-Disposition: attachment
  X-Content-Type-Options: nosniff
  X-Robots-Tag: noindex, nofollow
  Cache-Control: no-cache, max-age=0, must-revalidate

/assets/*
  Cache-Control: public, max-age=31536000, immutable
  X-Content-Type-Options: nosniff

/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()

/dhamet/*
  ! Permissions-Policy
  Permissions-Policy: camera=(), microphone=(self), geolocation=()
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin

/dhamet/assets/*
  Cache-Control: public, max-age=31536000, immutable
  X-Content-Type-Options: nosniff

/dhamet/css/*
  Cache-Control: no-cache, max-age=0, must-revalidate
  X-Content-Type-Options: nosniff

/dhamet/js/*
  Cache-Control: no-cache, max-age=0, must-revalidate
  X-Content-Type-Options: nosniff

/dhamet/shared/*
  Cache-Control: no-cache, max-age=0, must-revalidate
  X-Content-Type-Options: nosniff

/dhamet/*
  Content-Security-Policy: default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; form-action 'self'; script-src 'self' https://www.googletagmanager.com; script-src-attr 'none'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https://www.google-analytics.com https://www.googletagmanager.com; font-src 'self' data:; connect-src 'self' https://ouglsoft.com wss://ouglsoft.com https://www.google-analytics.com https://region1.google-analytics.com; media-src 'self' blob:; worker-src 'self' blob:; manifest-src 'self'; upgrade-insecure-requests
