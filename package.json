{
  "name": "ouglsoft",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare:pages": "node deploy/prepare-pages.mjs",
    "deploy:pages": "node deploy/deploy-pages.mjs",
    "deploy:worker": "node deploy/deploy-worker.mjs",
    "deploy": "npm run deploy:pages && npm run deploy:worker",
    "preview": "npm run prepare:pages && wrangler pages dev .deploy/site --functions functions"
  },
  "devDependencies": {
    "wrangler": "latest"
  },
  "cloudflare": {
    "pagesProjectName": "ouglsoft",
    "dhametPublicPath": "/dhamet",
    "dhametWorkerRoute": "ouglsoft.com/dhamet/api/*"
  },
  "dhametBuild": "computer-pvs-1.9.0"
}
